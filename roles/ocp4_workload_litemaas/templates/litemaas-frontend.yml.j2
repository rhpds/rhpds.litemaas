---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: litellm-frontend
  labels:
    app: litellm-frontend
    component: web
spec:
  replicas: 1
  selector:
    matchLabels:
      app: litellm-frontend
  template:
    metadata:
      labels:
        app: litellm-frontend
        component: web
    spec:
      initContainers:
{% if ocp4_workload_litemaas_branding_enabled | default(false) | bool %}
        - name: setup-branding
          image: busybox:1.36
          command:
            - sh
            - -c
            - |
              echo "Setting up branding assets..."
              mkdir -p /opt/app-root/src/branding
              cp /tmp/branding/logo-light.svg /opt/app-root/src/branding/
              cp /tmp/branding/logo-dark.svg /opt/app-root/src/branding/
              cp /tmp/branding/branding-inject.js /opt/app-root/src/branding/
              # Decode favicon from base64
              echo "/tmp/branding/favicon.png" | xargs cat | base64 -d > /opt/app-root/src/branding/favicon.png 2>/dev/null || cp /tmp/branding/favicon.png /opt/app-root/src/branding/favicon.png
              echo "Branding assets ready"
              ls -la /opt/app-root/src/branding/
          volumeMounts:
            - name: branding-assets
              mountPath: /tmp/branding
            - name: branding-volume
              mountPath: /opt/app-root/src/branding
{% endif %}
        - name: wait-for-backend
          image: busybox:1.36
          command:
            - sh
            - -c
            - |
              echo "Waiting for backend to be ready..."
              until nc -z litellm-backend 8080; do
                echo "Backend is not ready yet. Waiting..."
                sleep 5
              done
              echo "Backend is ready! Starting frontend..."
      containers:
        - name: frontend
          image: "{{ ocp4_workload_litemaas_frontend_image }}:{{ ocp4_workload_litemaas_version }}"
          ports:
            - containerPort: 8080
              name: http
          env:
            - name: BACKEND_URL
              value: "http://litellm-backend:8080"
          resources:
            requests:
              memory: "128Mi"
              cpu: "100m"
            limits:
              memory: "{{ ocp4_workload_litemaas_frontend_memory_limit }}"
              cpu: "{{ ocp4_workload_litemaas_frontend_cpu_limit }}"
          readinessProbe:
            httpGet:
              path: /
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          livenessProbe:
            httpGet:
              path: /
              port: 8080
            initialDelaySeconds: 30
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 3
{% if ocp4_workload_litemaas_branding_enabled | default(false) | bool %}
        - name: branding-proxy
          image: "{{ ocp4_workload_litemaas_frontend_image }}:{{ ocp4_workload_litemaas_version }}"
          command:
            - nginx
            - -c
            - /etc/nginx/branding/nginx.conf
            - -g
            - "daemon off;"
          ports:
            - containerPort: 8081
              name: branding
          volumeMounts:
            - name: branding-nginx-config
              mountPath: /etc/nginx/branding
            - name: branding-volume
              mountPath: /opt/app-root/src/branding
              readOnly: true
          resources:
            requests:
              memory: "64Mi"
              cpu: "50m"
            limits:
              memory: "128Mi"
              cpu: "100m"
          readinessProbe:
            httpGet:
              path: /
              port: 8081
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          livenessProbe:
            httpGet:
              path: /
              port: 8081
            initialDelaySeconds: 10
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 3
{% endif %}
{% if ocp4_workload_litemaas_branding_enabled | default(false) | bool %}
      volumes:
        - name: branding-assets
          configMap:
            name: litemaas-branding
        - name: branding-nginx-config
          configMap:
            name: litemaas-branding-nginx-config
        - name: branding-volume
          emptyDir: {}
{% endif %}
---
apiVersion: v1
kind: Service
metadata:
  name: litellm-frontend
  labels:
    app: litellm-frontend
    component: web
spec:
  ports:
    - port: 8080
{% if ocp4_workload_litemaas_branding_enabled | default(false) | bool %}
      targetPort: 8081
{% else %}
      targetPort: 8080
{% endif %}
      name: http
  selector:
    app: litellm-frontend
---
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: "{{ ocp4_workload_litemaas_frontend_route_name }}"
  labels:
    app: litellm-frontend
    component: web
  annotations:
    haproxy.router.openshift.io/timeout: 600s
spec:
  host: "{{ ocp4_workload_litemaas_frontend_route_prefix }}.{{ ocp4_workload_litemaas_cluster_domain }}"
  to:
    kind: Service
    name: litellm-frontend
  port:
    targetPort: http
  tls:
    termination: edge
    insecureEdgeTerminationPolicy: Redirect
